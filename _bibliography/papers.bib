@Article{Wei2021,
  author      = {Wei, Zhilong and Jiang, Qin and Nie, Sihang},
  journal     = {International Journal for Numerical Methods in Fluids},
  title       = {A pressure-based numerical scheme for compressible–incompressible two-phase flows},
  year        = {2021},
  issn        = {1097-0363},
  number      = {11},
  pages       = {3215--3230},
  volume      = {93},
  abstract    = {This article presents a numerical scheme for two-phase flows consisting of compressible gas and incompressible liquid. Assuming that the gas density is determined by pressure only and that the liquid density is constant, we develop a new set of governing equations for compressible–incompressible two-phase flows, which can be seen as a simplification of the previous unified governing equations. The volume fraction of gas, velocity, and pressure are the primary variables. Given the liquid's usual leading role in the flow motion, a pressure-based method is employed to solve the equations. A fifth-order accurate weighted essentially nonoscillatory (WENO) scheme is applied to discretize the advection terms, and the tangent of hyperbola for interface capturing (THINC) scheme is utilized to capture the interface. The numerical scheme proposed is validated against the generalized Bagnold model and the free drop of a water patch in a closed tank. The results show that the scheme can tackle low Mach number compressible–incompressible two-phase flows. For the one-dimensional Bagnold model, the present numerical model achieves first-order convergence and gives better results than that based on the previous unified governing equations with the same numerical methods. In the simulation of the free drop of a water patch in a closed tank, a similar pressure curve with other reported work is given.},
  copyright   = {© 2021 John Wiley \& Sons Ltd.},
  doi         = {10.1002/fld.5029},
  keywords    = {compressibility, governing equations, pressure-based method, THINC scheme, two-phase flow, WENO scheme},
  language    = {en},
  url         = {https://onlinelibrary.wiley.com/doi/abs/10.1002/fld.5029},
  html        = {https://onlinelibrary.wiley.com/doi/abs/10.1002/fld.5029},
  urldate     = {2022-08-05},
  bibtex_show = {true},
  pdf         = {Wei2021-A_pressure_based_numerical_scheme_for_compressible_incompressible_two_phase_flows.pdf},
  preview     = {Wei2021-water-patch.svg},
  selected    = {true}
}